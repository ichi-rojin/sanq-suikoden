{
  "name": "sanq-suikoden",
  "version": "0.0.0",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "sanq-suikoden",
      "version": "0.0.0",
      "workspaces": [
        "packages/*",
        "tools/*"
      ]
    },
    "node_modules/@world/cli": {
      "resolved": "packages/cli",
      "link": true
    },
    "node_modules/@world/core": {
      "resolved": "packages/core",
      "link": true
    },
    "node_modules/@world/tools-audit": {
      "resolved": "tools/audit",
      "link": true
    },
    "node_modules/@world/viewer": {
      "resolved": "packages/viewer",
      "link": true
    },
    "packages/cli": {
      "name": "@world/cli",
      "version": "0.0.0"
    },
    "packages/core": {
      "name": "@world/core",
      "version": "0.0.0"
    },
    "packages/viewer": {
      "name": "@world/viewer",
      "version": "0.0.0"
    },
    "tools/audit": {
      "name": "@world/tools-audit",
      "version": "0.0.0"
    }
  }

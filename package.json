{
  "name": "sanq-suikoden",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "tools/*"
  ],
  "scripts": {
    "dev:env": "npm run dev --workspace=@world/viewer",
    "typecheck": "tsc --build packages/core packages/cli packages/viewer tools/audit",
    "lint": "eslint .",
    "depcruise": "depcruise --config .dependency-cruiser.cjs packages/core/src packages/cli/src packages/viewer/src tools/audit/src",
    "test": "vitest run",
    "cli": "tsx packages/cli/src/main.ts",
    "validate-pack": "tsx packages/cli/src/main.ts validate-pack packs/fixtures/mini",
    "verify": "bash scripts/verify.sh"
  },
  "devDependencies": {
    "typescript": "^5.7.3",
    "eslint": "^9.18.0",
    "@eslint/js": "^9.18.0",
    "@typescript-eslint/eslint-plugin": "^8.21.0",
    "@typescript-eslint/parser": "^8.21.0",
    "eslint-plugin-import": "^2.31.0",
    "globals": "^15.14.0",
    "dependency-cruiser": "^16.8.0",
    "vitest": "^3.0.5",
    "tsx": "^4.19.2"
  }
}
